---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// MÁGICA: Aqui o código busca TODOS os posts da pasta 'guides' automaticamente
const allGuides = await getCollection('guides');

// Ordena os posts pelo número da 'order' que colocamos no topo de cada arquivo .md
const sortedGuides = allGuides.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Guia de Turismo Gramado e Canela 2026 | Seu Portal Completo na Serra">
  <article class="font-sans antialiased text-[#333]">

    <section class="bg-[#eee] py-20 px-6 text-center shadow-inner">
      <div class="max-w-[1200px] mx-auto bg-white p-6 rounded-2xl shadow-lg border border-gray-100 flex flex-col md:flex-row items-center gap-10">
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-[36px] md:text-[48px] font-black leading-[1.2] text-black tracking-tight mb-4">
            Descubra a Magia das Serras Gaúchas
          </h1>
          <p class="text-[18px] text-gray-700 leading-relaxed mb-8 max-w-[600px] mx-auto md:mx-0">
            Seu portal completo para Gramado, Canela e Serra Gaúcha em 2026. Dicas de roteiros de excelência, melhores preços e cupons exclusivos.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-3 max-w-[500px]">
             <input type="text" placeholder="O que você procura?" class="px-6 py-3 rounded-full border border-gray-200 w-full outline-none focus:border-[#0055ff]" />
             <button class="bg-[#ffcc00] text-black px-8 py-3 rounded-full font-bold hover:scale-105 transition-all">Buscar</button>
          </div>
        </div>
        <div class="flex-1">
          <img src="/portico-gramado.jpg" class="w-full h-auto rounded-xl shadow-sm border border-gray-100" alt="Pórtico de Gramado" />
        </div>
      </div>
    </section>

    <section class="bg-white py-16 px-6">
      <div class="max-w-[800px] mx-auto text-center">
        <h2 class="text-[32px] md:text-[40px] font-extrabold text-black tracking-tight mb-6">
          A Missão Deste Guia: Facilitar a Sua Viagem
        </h2>
        <div class="text-[18px] text-gray-800 leading-relaxed space-y-5 text-left md:text-center">
          <p>
            Olá, apaixonado por viagens. Este portal foi criado pensando exatamente em facilitar a vida dos que amam viajar, oferecendo uma **curadoria de excelência** para a Serra Gaúcha em 2026.
          </p>
        </div>
      </div>
    </section>

    <hr class="border-t border-gray-200" />

    <section class="max-w-[1200px] mx-auto px-6 py-16 bg-[#fafafa]">
      
      <h2 class="text-[28px] font-extrabold text-[#0055ff] tracking-tight mb-10">
        Explore o Nosso Guia Completo
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        {sortedGuides.map((guide) => (
          <a href={`/guia/${guide.slug}`} class="block bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-lg hover:border-[#0055ff] transition-all group flex flex-col h-full">
            <div class="flex flex-col sm:flex-row gap-6 items-center sm:items-start flex-grow">
              
              <img src={guide.data.heroImage} class="w-[140px] h-[140px] rounded-lg shadow-sm border border-gray-100 flex-shrink-0 object-cover" alt={guide.data.title} />
              
              <div class="flex-1 text-center sm:text-left">
                <h3 class="text-[20px] font-bold text-black mb-2 tracking-tight group-hover:text-[#0055ff] leading-tight">
                  {guide.data.title}
                </h3>
                <p class="text-[15px] text-gray-700 leading-relaxed mb-4 line-clamp-3">
                  {guide.body.substring(0, 160)}...
                </p>
              </div>
            </div>
            
            <div class="mt-4 pt-4 border-t border-gray-100 text-left">
              <span class="text-[#0055ff] text-[15px] font-semibold group-hover:underline">
                Continue lendo &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

  </article>
</Layout>
