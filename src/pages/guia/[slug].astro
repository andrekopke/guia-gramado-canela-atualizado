---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. getStaticPaths define as rotas dinâmicas para cada guia
export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

// 2. Coleta os dados do guia atual
const { guide } = Astro.props;
const { Content } = await guide.render();

// 3. Busca TODOS os guias para criar o "Leia também"
const allGuides = await getCollection('guides');

// 4. Filtra o guia ATUAL para não aparecer no "Leia também"
// e pega apenas os 3 primeiros restantes para a grade.
const otherGuides = allGuides
  .filter((g) => g.slug !== guide.slug)
  .slice(0, 3);
---

<Layout title={`${guide.data.title} | Guia Gramado e Canela 2026`}>
  <article class="font-sans antialiased text-[#333] bg-[#fafafa]">
    
    <header class="relative bg-gray-900 py-24 px-6 text-center text-white">
      <img src={guide.data.heroImage} alt={guide.data.title} class="absolute inset-0 w-full h-full object-cover opacity-30" />
      <div class="relative max-w-[800px] mx-auto z-10">
        <h1 class="text-[36px] md:text-[48px] font-black leading-[1.2] tracking-tight mb-4">
          {guide.data.title}
        </h1>
        <p class="text-[18px] opacity-90 max-w-[600px] mx-auto">
          Um guia completo e detalhado da Serra Gaúcha para planejar sua viagem em 2026 com excelência.
        </p>
      </div>
    </header>

    <main class="max-w-[800px] mx-auto bg-white p-8 md:p-12 rounded-2xl shadow-lg border border-gray-100 my-16">
      <div class="prose prose-lg prose-headings:font-extrabold prose-headings:text-black prose-p:text-gray-800 prose-p:leading-relaxed prose-a:text-[#0055ff] prose-a:no-underline hover:prose-a:underline prose-strong:font-semibold prose-img:rounded-xl prose-img:border prose-img:border-gray-100 max-w-none">
        <Content />
      </div>
    </main>

    <hr class="border-t border-gray-200" />

    <section class="max-w-[1200px] mx-auto px-6 py-16 bg-[#fafafa]">
      
      <h2 class="text-[28px] font-extrabold text-[#0055ff] tracking-tight mb-10 flex items-center gap-2">
        Leia também: Conteúdo Essencial para o seu Roteiro
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {otherGuides.map((otherGuide) => (
          <a href={`/guia/${otherGuide.slug}`} class="block bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-lg hover:border-[#0055ff] transition-all group flex flex-col h-full">
            <div class="flex-grow">
              <img src={otherGuide.data.heroImage} class="w-full h-auto rounded-lg shadow-sm border border-gray-100 mb-6 object-cover" alt={otherGuide.data.title} />
              
              <h3 class="text-[19px] font-bold text-black mb-2 tracking-tight group-hover:text-[#0055ff] leading-tight">
                {otherGuide.data.title}
              </h3>
            </div>
            
            <div class="mt-4 pt-4 border-t border-gray-100 text-left">
              <span class="text-[#0055ff] text-[15px] font-semibold flex items-center gap-1 group-hover:underline justify-start">
                Continue lendo o guia completo &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

  </article>
</Layout>
