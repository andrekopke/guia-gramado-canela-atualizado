---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

const posts = await getCollection('guides');

const orderedPosts = posts.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
) 

const firstPosts = orderedPosts.slice(0, 6);
const restPosts = orderedPosts.slice(6);
---

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Guia Gramado Canela</title>

    <meta name="description" content="Guia completo de Gramado e Canela com dicas atualizadas de viagem." />
    <link rel="preconnect" href="https://images.unsplash.com">
</head>

<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">

<header class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
    <!-- (SEU HEADER 100% INTACTO) -->
</header>

<main class="flex-grow">
    <slot />

<!-- 🔥 BLOCO AFILIADOS (SEU ORIGINAL) -->
<section class="container mx-auto px-4 mt-8">
  <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
    <h2 class="text-xl md:text-2xl font-bold mb-2">
      Garanta sua viagem com os melhores preços
    </h2>
    <p class="text-gray-600 mb-6">
      Compare hotéis, passagens e alugue carro com segurança — sem pagar mais caro por isso.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <a href="SEU_LINK_BOOKING" target="_blank"
         class="bg-blue-600 text-white p-5 rounded-xl text-center">
        🏨 <div class="font-bold">Hotéis</div>
      </a>

      <a href="SEU_LINK_PASSAGENS" target="_blank"
         class="bg-orange-500 text-white p-5 rounded-xl text-center">
        ✈️ <div class="font-bold">Passagens</div>
      </a>

      <a href="SEU_LINK_CARROS" target="_blank"
         class="bg-gray-800 text-white p-5 rounded-xl text-center">
        🚗 <div class="font-bold">Carros</div>
      </a>

    </div>
  </div>
</section>

</main>

<!-- 🔥 RODAPÉ COMPLETO (RESTAURADO) -->
<footer class="bg-gray-900 text-white mt-16 pt-16 pb-8">
    <div class="container mx-auto px-4">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">

            <div>
                <h4 class="text-xl font-black italic uppercase">
                    GUIA <span class="text-yellow-400">SERRAS</span>
                </h4>
                <p class="text-gray-400 text-sm mt-4">
                    Seu guia completo para viajar melhor, economizar e aproveitar mais.
                </p>
            </div>

            <div>
                <h5 class="text-sm font-bold uppercase tracking-widest text-yellow-400 mb-6">
                    Informações
                </h5>
                <ul class="space-y-3 text-sm text-gray-300">
                    <li><a href="/sobre">Quem Somos</a></li>
                    <li><a href="/contato">Contato</a></li>
                    <li><a href="/politica-de-privacidade">Privacidade</a></li>
                    <li><a href="/termos-de-uso">Termos</a></li>
                </ul>
            </div>

        </div>

        <div class="border-t border-gray-800 pt-8 text-xs text-gray-500 text-center">
            © 2026 Guia Gramado Canela
        </div>

    </div>
</footer>

<!-- 🔥 BARRA FIXA DINÂMICA (ADICIONADA SEM QUEBRAR NADA) -->
<div class="fixed bottom-0 left-0 w-full bg-white border-t shadow-2xl z-50 md:hidden">

  <div class="grid grid-cols-5 text-center text-[10px] font-bold">

    <a id="btn-hotel" href="SEU_LINK_BOOKING" target="_blank" class="py-2 text-blue-600">
      🏨 <div>Hotéis</div>
    </a>

    <a id="btn-passagem" href="SEU_LINK_PASSAGENS" target="_blank" class="py-2 text-orange-500">
      ✈️ <div>Voos</div>
    </a>

    <a id="btn-carro" href="SEU_LINK_CARROS" target="_blank" class="py-2 text-gray-800">
      🚗 <div>Carros</div>
    </a>

    <a id="btn-ingresso" href="SEU_LINK_INGRESSOS" target="_blank" class="py-2 text-purple-600">
      🎟️ <div>Ingressos</div>
    </a>

    <a id="btn-seguro" href="SEU_LINK_SEGURO" target="_blank" class="py-2 text-green-600">
      🛡️ <div>Seguro</div>
    </a>

  </div>

</div>

<!-- espaço para não cobrir conteúdo -->
<div class="h-20 md:hidden"></div>

<!-- 🔥 SCRIPT INTELIGENTE (DINÂMICO POR PÁGINA) -->
<script>
const url = window.location.pathname;

if (url.includes("onde-ficar")) {
  document.getElementById("btn-hotel").style.transform = "scale(1.1)";
}

if (url.includes("como-chegar")) {
  document.getElementById("btn-passagem").style.transform = "scale(1.1)";
}

if (url.includes("o-que-fazer")) {
  document.getElementById("btn-ingresso").style.transform = "scale(1.1)";
}
</script>

</body>
</html>
