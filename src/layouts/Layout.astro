---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

// 🔥 SUA COLLECTION (mantida)
const posts = await getCollection('guides');

// 🔥 ORDENAÇÃO
const orderedPosts = posts.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);

// 🔥 LIMITA PRIMEIRA CARGA (SEO + performance)
const firstPosts = orderedPosts.slice(0, 6);
const restPosts = orderedPosts.slice(6);
---

<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Guia Gramado e Canela</title>
</head>

<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">

<!-- HEADER -->
<header class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
  <div class="container mx-auto px-4 py-3 flex justify-between items-center">
    <a href="/" class="text-2xl font-black uppercase">
      GUIA <span class="text-yellow-400">SERRAS</span>
    </a>
  </div>
</header>

<main class="flex-grow">

  <slot />

  <!-- 🔥 BLOCO TIPO SITE GRANDE -->
  <section class="container mx-auto px-4 mt-16">

    <div class="bg-white p-6 rounded-xl shadow mb-8 text-center">
      <h2 class="text-xl md:text-2xl font-bold">
        Veja mais dicas especiais nos posts abaixo
      </h2>
    </div>

    <!-- GRID -->
    <div id="posts-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">

      {firstPosts.map((post) => (
        <a href={`/guides/${post.slug}/`} class="block group">
          <div class="bg-white rounded-xl overflow-hidden shadow hover:shadow-lg transition">

            <img
              src={post.data.heroImage}
              alt={post.data.title}
              loading="lazy"
              class="w-full h-48 object-cover"
            />

            <div class="p-4">
              <h3 class="font-bold text-lg mb-2 group-hover:text-blue-700">
                {post.data.title}
              </h3>

              <p class="text-sm text-gray-600">
                {post.data.description}
              </p>
            </div>

          </div>
        </a>
      ))}

    </div>

    <!-- LOADER -->
    <div id="loader" class="text-center py-10 text-gray-500">
      Carregando mais posts...
    </div>

  </section>

</main>

<footer class="bg-gray-900 text-white mt-16 p-6 text-center text-sm">
  © 2026 Guia Gramado e Canela
</footer>

<!-- 🚀 INFINITE SCROLL PROFISSIONAL -->
<script>
  const restPosts = JSON.parse(`${
    JSON.stringify(
      restPosts.map(post => ({
        slug: post.slug,
        title: post.data.title,
        description: post.data.description,
        heroImage: post.data.heroImage
      }))
    )
  }`);

  let index = 0;
  const perLoad = 6;

  const grid = document.getElementById('posts-grid');
  const loader = document.getElementById('loader');

  function loadMore() {
    const nextPosts = restPosts.slice(index, index + perLoad);

    nextPosts.forEach(post => {
      const card = document.createElement('a');
      card.href = `/guides/${post.slug}/`;
      card.className = "block";

      card.innerHTML = `
        <div class="bg-white rounded-xl overflow-hidden shadow hover:shadow-lg transition">
          <img src="${post.heroImage}" class="w-full h-48 object-cover" loading="lazy"/>
          <div class="p-4">
            <h3 class="font-bold text-lg mb-2">${post.title}</h3>
            <p class="text-sm text-gray-600">${post.description}</p>
          </div>
        </div>
      `;

      grid.appendChild(card);
    });

    index += perLoad;

    if (index >= restPosts.length) {
      loader.innerText = "Fim dos posts";
      window.removeEventListener('scroll', handleScroll);
    }
  }

  function handleScroll() {
    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 300) {
      loadMore();
    }
  }

  window.addEventListener('scroll', handleScroll);
</script>

</body>
</html>
