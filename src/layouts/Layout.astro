---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

const posts = await getCollection('blog');
const orderedPosts = posts.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);
---

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Guia Gramado e Canela</title>

    <!-- 🔥 REMOVE SCROLL AUTOMÁTICO DO NAVEGADOR -->
    <script>
      history.scrollRestoration = "manual";
    </script>

    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
</head>

<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">

<!-- HEADER PADRÃO (IGUAL TODAS PÁGINAS) -->
<header class="bg-blue-800 text-white shadow-md sticky top-0 z-50">

  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- LOGO ESQUERDA -->
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" style="height:60px;" />
      <span class="font-bold text-lg hidden sm:block">
        Guia Gramado Canela
      </span>
    </a>

    <!-- MENU DIREITA -->
    <nav class="flex gap-6 text-sm font-bold">
      <a href="/" class="hover:text-yellow-300">Home</a>
      <a href="/sobre/" class="hover:text-yellow-300">Sobre</a>
    </nav>

  </div>

</header>

<!-- HERO PADRÃO (SÓ HOME MOSTRA GRANDE) -->
<div id="hero" class="w-full bg-black">
  <img 
    src="/portico-gramado-rs.jpg"
    style="width:100%; height:320px; object-fit:cover;"
  />
</div>

<!-- CONTEÚDO -->
<main class="flex-grow max-w-3xl mx-auto px-4 py-6">
  <slot />
</main>

<!-- 🔥 CONTINUAR LENDO (PADRÃO MELHORES DESTINOS) -->
<section class="max-w-6xl mx-auto px-4 mb-16">

  <h2 class="text-xl font-bold mb-6">
    Continuar lendo
  </h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">

    {orderedPosts.map((post) => (
      <a href={`/blog/${post.slug}/`} class="block">

        <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition">

          <img
            src={post.data.heroImage}
            alt={post.data.title}
            style="width:100%; height:140px; object-fit:cover;"
          />

          <div class="p-3">
            <h3 class="text-sm font-bold leading-tight">
              {post.data.title}
            </h3>
          </div>

        </div>

      </a>
    ))}

  </div>

</section>

<!-- FOOTER -->
<footer class="bg-blue-900 text-white text-center py-10">
  <p>&copy; 2026 Guia Gramado Canela</p>
</footer>

<!-- 🔥 SCRIPT QUE RESOLVE SEU PROBLEMA -->
<script>
  // 👇 ISSO É O QUE FALTAVA NO SEU SITE

  document.addEventListener("click", function (e) {
    const link = e.target.closest("a");

    if (!link) return;

    const url = link.getAttribute("href");

    // Só controla links internos
    if (url && url.startsWith("/")) {

      sessionStorage.setItem("scrollFix", "true");
    }
  });

  window.addEventListener("load", () => {
    if (sessionStorage.getItem("scrollFix")) {

      // 👇 vai direto pro conteúdo (SEM mostrar hero piscando)
      const main = document.querySelector("main");

      if (main) {
        main.scrollIntoView({ behavior: "instant" });
      }

      sessionStorage.removeItem("scrollFix");
    }
  });
</script>

</body>
</html>
