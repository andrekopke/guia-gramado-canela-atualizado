---
import { getCollection } from 'astro:content';

interface Props { title: string; }
const { title } = Astro.props;

const posts = await getCollection('guides');

const orderedPosts = posts.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder
);

const firstPosts = orderedPosts.slice(0, 6);
const restPosts = orderedPosts.slice(6);
---

<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Guia Gramado Canela</title>

    <meta name="description" content="Guia completo de Gramado e Canela com dicas atualizadas de viagem." />
    <link rel="preconnect" href="https://images.unsplash.com">
</head>

<body class="bg-gray-50 font-sans text-gray-900 flex flex-col min-h-screen">

<header class="bg-blue-800 text-white shadow-lg sticky top-0 z-50">
...
</header>

<main class="flex-grow">
    <slot />

<!-- 🔥 BARRA ULTRA CONVERSÃO -->
<div id="bar-container" class="fixed bottom-0 left-0 w-full z-50 md:hidden opacity-0 translate-y-20 transition-all duration-500">

  <div class="bg-gradient-to-r from-blue-700 to-blue-900 text-white shadow-2xl">

    <div class="flex justify-between items-center px-2 py-2 text-[10px] font-bold">

      <a id="btn-hotel" href="SEU_LINK_BOOKING" target="_blank" class="flex flex-col items-center flex-1">
        🏨
        <span>Hotéis</span>
      </a>

      <a id="btn-passagem" href="SEU_LINK_PASSAGENS" target="_blank" class="flex flex-col items-center flex-1">
        ✈️
        <span>Voos</span>
      </a>

      <!-- BOTÃO CENTRAL -->
      <a id="btn-main" href="SEU_LINK_BOOKING" target="_blank"
         class="flex flex-col items-center flex-1 bg-yellow-400 text-black py-2 px-3 rounded-xl shadow-lg transition-all duration-300">
        🔥
        <span id="main-text">Ver Ofertas</span>
        <span id="urgency" class="text-[9px] font-normal"></span>
      </a>

      <a id="btn-carro" href="SEU_LINK_CARROS" target="_blank" class="flex flex-col items-center flex-1">
        🚗
        <span>Carros</span>
      </a>

      <a id="btn-ingresso" href="SEU_LINK_INGRESSOS" target="_blank" class="flex flex-col items-center flex-1">
        🎟️
        <span>Ingressos</span>
      </a>

    </div>

  </div>

</div>

<div class="h-20 md:hidden"></div>

</main>

<footer class="bg-gray-900 text-white mt-16 pt-16 pb-8">
...
</footer>

<script>
const restPosts = JSON.parse(`${JSON.stringify(
restPosts.map(post => ({
slug: post.slug,
title: post.data.title,
description: post.data.description,
heroImage: post.data.heroImage
}))
)}`);
</script>

<!-- 🔥 SCRIPT INTELIGENTE -->
<script>
const url = window.location.pathname;

const mainBtn = document.getElementById("btn-main");
const mainText = document.getElementById("main-text");
const urgency = document.getElementById("urgency");
const bar = document.getElementById("bar-container");

// 🎯 CONTEXTO
if (url.includes("onde-ficar")) {
  mainText.innerText = "Ver Hotéis Baratos";
  mainBtn.href = "SEU_LINK_BOOKING";
}

if (url.includes("como-chegar")) {
  mainText.innerText = "Ver Passagens Promo";
  mainBtn.href = "SEU_LINK_PASSAGENS";
}

if (url.includes("o-que-fazer")) {
  mainText.innerText = "Comprar Ingressos";
  mainBtn.href = "SEU_LINK_INGRESSOS";
}

if (url.includes("roteiro")) {
  mainText.innerText = "Montar Viagem";
  mainBtn.href = "SEU_LINK_BOOKING";
}

// 🚀 APARECE AO ROLAR
window.addEventListener("scroll", () => {
  if (window.scrollY > 300) {
    bar.classList.remove("opacity-0", "translate-y-20");
  }
});

// 🔥 URGÊNCIA DINÂMICA
function updateUrgency() {
  const num = Math.floor(Math.random() * 12) + 3;
  urgency.innerText = num + " pessoas vendo agora";
}
setInterval(updateUrgency, 4000);
updateUrgency();

// ⚡ PULSE NO BOTÃO (atenção visual)
setInterval(() => {
  mainBtn.classList.add("scale-110");
  setTimeout(() => {
    mainBtn.classList.remove("scale-110");
  }, 300);
}, 3000);

</script>

</body>
</html>
